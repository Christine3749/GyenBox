{
  "name": "@gyenbox/db",
  "version": "0.1.19",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "npm run generate && tsc --noEmit",
    "generate": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests for @gyenbox/db yet\"",
    "migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "typescript": "^5.7.3"
  }
}
