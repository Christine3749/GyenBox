{
  "$schema": "../../../node_modules/wrangler/config-schema.json",
  "name": "gyenbox-origin-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-27",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "gyenbox.com/*",
      "zone_name": "gyenbox.com"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "GYENBOX_ORIGIN": "https://gyenbox-web-tw-1004693447123.asia-east1.run.app"
  }
}
