{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "isolatedModules": false
  },
  "include": ["src/**/*.ts"]
}
