{
  "name": "gyenbox",
  "version": "0.1.14",
  "private": true,
  "description": "GyenBox privacy-first cloud storage monorepo.",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@gyenbox/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "npm --workspace @gyenbox/db run generate",
    "db:migrate": "npm --workspace @gyenbox/db run migrate",
    "format": "prettier --write .",
    "desktop:dev": "npm --workspace @gyenbox/desktop run dev",
    "desktop:build": "npm --workspace @gyenbox/desktop run build"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "prettier": "^3.5.3",
    "prisma": "6.19.3",
    "turbo": "^2.8.0",
    "typescript": "^5.7.3"
  }
}
