# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://hrtynofmjcumuanjvpxz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-publishable-or-anon-key
SUPABASE_URL=https://hrtynofmjcumuanjvpxz.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-publishable-or-anon-key

# Postgres metadata database (Supabase Postgres or Cloud SQL Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT=gyenbox
GCS_BUCKET=gyenbox-files-PROJECT_NUMBER

# Upload controls
MAX_UPLOAD_BYTES=5368709120

# Local-only API bypass for tests/dev when Supabase is absent
ALLOW_UNVERIFIED_ACTOR_HEADER=false
